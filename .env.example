# Required for LLM-backed refinement, concept generation, optimizer script generation,
# and OpenAI-backed part selection.
OPENAI_API_KEY=your_openai_api_key

# Default model used by full-pipeline Python stages unless overridden on the CLI.
OPENAI_MODEL=gpt-5-mini

# Required for `syside check` inside the pipeline venv.
SYSIDE_LICENSE_KEY=your_syside_license_key

# Optional: if you have a private/public pip spec for SysIDE, the setup script can
# install it into `SysMLtoDesignInstance/.venv`.
# Example: SYSIDE_PIP_SPEC=syside
SYSIDE_PIP_SPEC=

# Optional supplier/API credentials used by the component finder.
MOUSER_API_KEY=
MOUSER_BASE_URL=https://api.mouser.com/api/v1/search/keyword

DIGIKEY_CLIENT_ID=
DIGIKEY_CLIENT_SECRET=
DIGIKEY_REFRESH_TOKEN=
DIGIKEY_BASE_URL=https://api.digikey.com
DIGIKEY_LOCALE_SITE=US
DIGIKEY_LOCALE_LANG=en
DIGIKEY_LOCALE_CURRENCY=USD

OCTOPART_API_KEY=
NEXAR_TOKEN=
NEXAR_GRAPHQL_URL=https://api.nexar.com/graphql

# Optional Gemini key for the configurator UI/browser app.
GEMINI_API_KEY=

# Optional behavior toggles for supplier lookup.
USE_MOCK=0
DISABLE_OCTOPART=0
DISABLE_WEB_SEARCH=0

# Optional pipeline tuning.
PART_SEARCH_TIMEOUT_SEC=180
OPTIMIZER_TIMEOUT_SEC=240
PIPELINE_MAX_PARALLEL_CONCEPTS=0
OPTIMIZER_SCRIPT_MODEL=gpt-5-mini
